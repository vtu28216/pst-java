import java.util.Scanner;
public class bs{
    public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int[] a={10,20,30,40,50,60,70,80,90};
    int key=sc.nextInt();
    int l=0,h=9;
    while(l<=h){
        int m=(l+h)/2;
        if(a[m]==key){
            System.out.println("Found");
            return;}
            if(key<a[m])
            h=m-1;
            else
            l=m+1;
        }
    System.out.println("Not found");
    }
}
